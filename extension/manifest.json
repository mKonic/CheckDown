{
  "manifest_version": 3,
  "name": "CheckDown - Download Manager",
  "description": "Intercept downloads and send them to CheckDown download manager for faster, segmented downloading.",
  "version": "1.0.0",
  "permissions": [
    "downloads",
    "contextMenus",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:18693/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
